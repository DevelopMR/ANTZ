{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Ant Sim: Debug in Edge",
      "type": "msedge",
      "request": "launch",
      "url": "http://localhost:8000",
      "webRoot": "${workspaceFolder}",
      "preLaunchTask": "ant-sim: start server"
    },
    {
      "name": "Ant Sim: Attach to Edge",
      "type": "msedge",
      "request": "attach",
      "port": 9222,
      "webRoot": "${workspaceFolder}"
    },
    {
      "name": "Ant Sim: Debug in Chrome",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:8000",
      "webRoot": "${workspaceFolder}",
      "preLaunchTask": "ant-sim: start server"
    }
  ]
}
