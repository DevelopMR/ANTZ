{
  "version": "0.2",
  "language": "en,en-US",
  "allowCompoundWords": true,
  "useGitignore": true,
  "dictionaryDefinitions": [
    {
      "name": "antz-project",
      "path": "./.cspell/antz-words.txt",
      "addWords": false
    }
  ],
  "dictionaries": [
    "softwareTerms",
    "npm",
    "node",
    "html",
    "css",
    "typescript",
    "filetypes",
    "shell",
    "powershell",
    "company-terms",
    "antz-project"
  ],
  "ignorePaths": [
    ".git",
    "node_modules",
    "package-lock.json"
  ],
  "files": [
    "**/*.md",
    "**/*.js",
    "**/*.json"
  ]
}
